# UltraGameStudio Remote Runner configuration
# Copy to .env and adjust. All values are optional except UGS_RUNNER_TOKEN.

# Bearer token the desktop client must send. REQUIRED in production.
# Local Windows launchers fill this with a stable machine-derived token when blank.
# Production/public servers should set a strong manual token instead.
UGS_RUNNER_TOKEN=
# Backward-compatible alias:
FUC_RUNNER_TOKEN=

# Bind address / port.
UGS_RUNNER_HOST=0.0.0.0
UGS_RUNNER_PORT=8787

# Where cloned repos / job working dirs live on this server.
UGS_RUNNER_WORKDIR=./workspaces

# Persistent metadata (jobs index, workspace records).
UGS_RUNNER_DATADIR=./data

# Max concurrent jobs.
UGS_RUNNER_MAX_CONCURRENCY=2

# Per-job wall-clock timeout (seconds).
UGS_RUNNER_JOB_TIMEOUT=1800

# Comma-separated allowlist of shell commands the AI agent may invoke directly
# via the /exec endpoint. Empty = exec endpoint disabled.
UGS_RUNNER_EXEC_ALLOWLIST=

# Optional multi-account pool. The runner picks the lowest-usage matching
# account for each job, then records token totals per account.
# Keep this on one line in .env.
# UGS_RUNNER_ACCOUNTS=[{"id":"claude-main","label":"Claude 主号","adapter":"claude","apiKeyEnv":"ANTHROPIC_API_KEY","model":"claude-sonnet-4-20250514","monthlyTokenLimit":50000000},{"id":"codex-main","label":"Codex 主号","adapter":"codex","apiKeyEnv":"OPENAI_API_KEY","model":"gpt-5.1-codex","monthlyTokenLimit":50000000}]

# --- Model defaults (the server's OWN keys; clients may override per job) ---
# These let you keep keys on the server instead of shipping them from clients.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
